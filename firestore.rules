rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function isCustomer() {
      return isSignedIn() && userDoc().data.role == 'customer';
    }

    function isProvider() {
      return isSignedIn() && userDoc().data.role == 'provider';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function requestDoc(id) {
      return get(/databases/$(database)/documents/requests/$(id));
    }

    function validProviderTransition(from, to) {
      return (from == 'accepted' && to == 'onTheWay') ||
        (from == 'onTheWay' && to == 'arrived') ||
        (from == 'arrived' && to == 'inService') ||
        (from == 'inService' && to == 'completed') ||
        from == to;
    }

    function canReadRequest(data) {
      return isAdmin() ||
        (isCustomer() && data.customerUid == request.auth.uid) ||
        (isProvider() && (
          data.providerUid == request.auth.uid ||
          data.offeredProviderUid == request.auth.uid
        ));
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // PROVIDERS
    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(providerId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(providerId) || isAdmin());
      allow delete: if isAdmin();
    }

    // REQUESTS (CRITICAL)
    match /requests/{requestId} {

      allow read: if isSignedIn() && canReadRequest(resource.data);

      // only customer creates request
      allow create: if isCustomer() &&
        request.resource.data.customerUid == request.auth.uid &&
        request.resource.data.status == 'searching' &&
        request.resource.data.providerUid == null &&
        request.resource.data.offeredProviderUid == null;

      // UPDATE RULES
      allow update: if isSignedIn() && (
        isAdmin()

        // customer can only cancel own request
        || (isCustomer() &&
            resource.data.customerUid == request.auth.uid &&
            resource.data.status != 'completed' &&
            resource.data.status != 'cancelled' &&
            request.resource.data.status == 'cancelled')

        // offered provider can reject current offer
        || (isProvider() && (
          (
            resource.data.status == 'searching' &&
            resource.data.offeredProviderUid == request.auth.uid &&
            request.resource.data.status == 'searching' &&
            request.resource.data.providerUid == null &&
            request.resource.data.offeredProviderUid == null
          ) ||
          (
            resource.data.status == 'searching' &&
            resource.data.offeredProviderUid == request.auth.uid &&
            request.resource.data.status == 'accepted' &&
            request.resource.data.providerUid == request.auth.uid &&
            request.resource.data.offeredProviderUid == null
          ) ||
          (
            resource.data.providerUid == request.auth.uid &&
            request.resource.data.providerUid == request.auth.uid &&
            validProviderTransition(
              resource.data.status,
              request.resource.data.status,
            )
          )
        ))
      );

      allow delete: if isAdmin();
    }

    // TRACKING (STRICT)
    match /tracking/{requestId} {
      allow read: if isSignedIn() &&
        canReadRequest(requestDoc(requestId).data);

      allow write: if isProvider() &&
        requestDoc(requestId).data.providerUid == request.auth.uid;
    }

    // ADMIN CONFIG
    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_notifications/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /request_chats/{requestId} {
      allow read, write: if isSignedIn() &&
        canReadRequest(requestDoc(requestId).data);

      match /messages/{messageId} {
        allow read, write: if isSignedIn() &&
          canReadRequest(requestDoc(requestId).data);
      }
    }

    // CHAT fallback
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }
  }
}
