rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function isCustomer() {
      return isSignedIn() && userDoc().data.role == 'customer';
    }

    function isProvider() {
      return isSignedIn() && userDoc().data.role == 'provider';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isPublicRole(role) {
      return role == 'customer' || role == 'provider';
    }

    function isValidSelfUserCreate(userId) {
      return isOwner(userId) &&
        request.resource.data.uid == userId &&
        isPublicRole(request.resource.data.role) &&
        request.resource.data.email is string &&
        request.resource.data.fullName is string &&
        request.resource.data.phone is string &&
        request.resource.data.isBlocked != true &&
        (
          (request.resource.data.role == 'customer' &&
            request.resource.data.isApproved == true) ||
          (request.resource.data.role == 'provider' &&
            request.resource.data.isApproved == false)
        );
    }

    function isSafeSelfUserUpdate(userId) {
      return isOwner(userId) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.isApproved == resource.data.isApproved &&
        request.resource.data.isBlocked == resource.data.isBlocked;
    }

    function isValidSelfProviderCreate(providerId) {
      return isOwner(providerId) &&
        request.resource.data.uid == providerId &&
        request.resource.data.isApproved == false &&
        request.resource.data.isBlocked != true;
    }

    function isSafeSelfProviderUpdate(providerId) {
      return isOwner(providerId) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.isApproved == resource.data.isApproved &&
        request.resource.data.isBlocked == resource.data.isBlocked;
    }

    function requestDoc(id) {
      return get(/databases/$(database)/documents/requests/$(id));
    }

    function validProviderTransition(from, to) {
      return (from == 'accepted' && to == 'onTheWay') ||
        (from == 'onTheWay' && to == 'arrived') ||
        (from == 'arrived' && to == 'inService') ||
        (from == 'inService' && to == 'completed') ||
        from == to;
    }

    function canReadRequest(data) {
      return isAdmin() ||
        (isCustomer() && data.customerUid == request.auth.uid) ||
        (isProvider() && (
          data.providerUid == request.auth.uid ||
          data.offeredProviderUid == request.auth.uid
        ));
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && (isValidSelfUserCreate(userId) || isAdmin());
      allow update: if isSignedIn() && (isSafeSelfUserUpdate(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // PROVIDERS
    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isValidSelfProviderCreate(providerId) || isAdmin());
      allow update: if isSignedIn() && (isSafeSelfProviderUpdate(providerId) || isAdmin());
      allow delete: if isAdmin();
    }

    // REQUESTS (CRITICAL)
    match /requests/{requestId} {

      allow read: if isSignedIn() && canReadRequest(resource.data);

      // only customer creates request
      allow create: if isCustomer() &&
        request.resource.data.customerUid == request.auth.uid &&
        request.resource.data.status == 'searching' &&
        request.resource.data.providerUid == null &&
        request.resource.data.offeredProviderUid == null;

      // UPDATE RULES
      allow update: if isSignedIn() && (
        isAdmin()

        // customer can only cancel own request
        || (isCustomer() &&
            resource.data.customerUid == request.auth.uid &&
            resource.data.status != 'completed' &&
            resource.data.status != 'cancelled' &&
            request.resource.data.status == 'cancelled')

        // offered provider can reject current offer
        || (isProvider() && (
          (
            resource.data.status == 'searching' &&
            resource.data.offeredProviderUid == request.auth.uid &&
            request.resource.data.status == 'searching' &&
            request.resource.data.providerUid == null &&
            request.resource.data.offeredProviderUid == null
          ) ||
          (
            resource.data.status == 'searching' &&
            resource.data.offeredProviderUid == request.auth.uid &&
            request.resource.data.status == 'accepted' &&
            request.resource.data.providerUid == request.auth.uid &&
            request.resource.data.offeredProviderUid == null
          ) ||
          (
            resource.data.providerUid == request.auth.uid &&
            request.resource.data.providerUid == request.auth.uid &&
            validProviderTransition(
              resource.data.status,
              request.resource.data.status,
            )
          )
        ))
      );

      allow delete: if isAdmin();
    }

    // TRACKING (STRICT)
    match /tracking/{requestId} {
      allow read: if isSignedIn() &&
        canReadRequest(requestDoc(requestId).data);

      allow write: if isProvider() &&
        requestDoc(requestId).data.providerUid == request.auth.uid;
    }

    // ADMIN CONFIG
    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_notifications/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /request_chats/{requestId} {
      allow read, write: if isSignedIn() &&
        canReadRequest(requestDoc(requestId).data);

      match /messages/{messageId} {
        allow read, write: if isSignedIn() &&
          canReadRequest(requestDoc(requestId).data);
      }
    }

    // CHAT fallback
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }
  }
}
