rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() &&
        currentUserDoc().data.role == 'admin';
    }

    function isCustomer() {
      return isSignedIn() &&
        currentUserDoc().data.role == 'customer';
    }

    function isProvider() {
      return isSignedIn() &&
        currentUserDoc().data.role == 'provider';
    }

    function requestDoc(requestId) {
      return get(/databases/$(database)/documents/requests/$(requestId));
    }

    function canReadRequest(data) {
      return isAdmin() ||
        (isCustomer() && data.customerUid == request.auth.uid) ||
        (isProvider() && (
          data.providerUid == request.auth.uid ||
          data.offeredProviderUid == request.auth.uid
        ));
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || isAdmin()
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == providerId || isAdmin()
      );
      allow update: if isSignedIn() && (
        request.auth.uid == providerId || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isSignedIn() && canReadRequest(resource.data);

      allow create: if isCustomer() &&
        request.resource.data.customerUid == request.auth.uid;

      allow update: if isSignedIn() && (
        isAdmin() ||
        (isCustomer() &&
          resource.data.customerUid == request.auth.uid) ||
        (isProvider() && (
          resource.data.providerUid == request.auth.uid ||
          resource.data.offeredProviderUid == request.auth.uid
        ))
      );

      allow delete: if isAdmin();
    }

    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_notifications/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }

    match /tracking/{trackingId} {
      allow read: if isSignedIn() && canReadRequest(requestDoc(trackingId).data);
      allow write: if isAdmin() || isProvider();
    }
  }
}