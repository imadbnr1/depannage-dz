rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function isCustomer() {
      return isSignedIn() && userDoc().data.role == 'customer';
    }

    function isProvider() {
      return isSignedIn() && userDoc().data.role == 'provider';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function requestDoc(id) {
      return get(/databases/$(database)/documents/requests/$(id));
    }

    function canReadRequest(data) {
      return isAdmin() ||
        (isCustomer() && data.customerUid == request.auth.uid) ||
        (isProvider() && (
          data.providerUid == request.auth.uid ||
          data.offeredProviderUid == request.auth.uid
        ));
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // PROVIDERS
    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(providerId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(providerId) || isAdmin());
      allow delete: if isAdmin();
    }

    // REQUESTS (CRITICAL)
    match /requests/{requestId} {

      allow read: if isSignedIn() && canReadRequest(resource.data);

      // only customer creates request
      allow create: if isCustomer() &&
        request.resource.data.customerUid == request.auth.uid;

      // UPDATE RULES
      allow update: if isSignedIn() && (
        isAdmin()

        // customer can cancel own request
        || (isCustomer() &&
            resource.data.customerUid == request.auth.uid)

        // provider logic
        || (isProvider() && (
          // accept only if offered
          resource.data.offeredProviderUid == request.auth.uid

          // OR already assigned provider
          || resource.data.providerUid == request.auth.uid
        ))
      );

      allow delete: if isAdmin();
    }

    // TRACKING (STRICT)
    match /tracking/{requestId} {
      allow read: if isSignedIn() &&
        canReadRequest(requestDoc(requestId).data);

      allow write: if isProvider() &&
        requestDoc(requestId).data.providerUid == request.auth.uid;
    }

    // ADMIN CONFIG
    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_notifications/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CHAT (basic for now)
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }
  }
}